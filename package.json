{
  "name": "audio-transcoding-server",
  "type": "module",
  "version": "1.0.0",
  "description": "Audio transcoding server to change audio format while preserving metadata",
  "license": "MIT",
  "author": "Seva Zaikov <mail@bloomca.me>",
  "scripts": {
    "dev:redis": "docker compose -f docker-compose.dev.yml up redis",
    "dev:server": "wait-on tcp:6379 && tsx watch src/server/index.ts",
    "dev:worker": "wait-on tcp:6379 && tsx watch src/worker/index.ts",
    "dev:client": "vite",
    "dev": "concurrently -k \"npm run dev:redis\" \"npm run dev:server\" \"npm run dev:worker\" \"npm run dev:client\"",
    "build:server": "tsc -p tsconfig.json",
    "build:client": "vite build",
    "build": "npm run build:server && npm run build:client",
    "start:server": "node dist/server/index.js",
    "start:worker": "node dist/worker/index.js",
    "test": "vitest",
    "test:client": "vitest run src/client",
    "test:server": "vitest run src/server",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check": "biome check .",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/form-data": "^2.2.1",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "form-data": "^4.0.5",
    "husky": "^9.1.7",
    "jsdom": "^26.1.0",
    "lint-staged": "^16.4.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.1",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.4"
  },
  "lint-staged": {
    "*.{js,mjs,cjs,jsx,ts,mts,cts,tsx,json,jsonc,css}": "biome check --write --files-ignore-unknown=true"
  },
  "dependencies": {
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "bullmq": "^5.71.0",
    "fastify": "^5.8.2",
    "fflate": "^0.8.2",
    "prom-client": "^15.1.3",
    "veles": "^1.0.0-alpha.2"
  }
}
