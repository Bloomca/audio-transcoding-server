# Public port on the VPS host mapped to server container port 3000
HOST_PORT=3000

# Internal Redis URL used by server + worker within docker compose network
REDIS_URL=redis://redis:6379

# Shared path mounted in both server and worker containers
STORAGE_PATH=/data/audio-transcoding

# Max upload file size (MB)
MAX_FILE_SIZE_MB=100

# Max number of jobs in waiting+active+delayed states
MAX_QUEUE_DEPTH=30

# Retry hint (seconds) returned with HTTP 503 when queue is full
QUEUE_BUSY_RETRY_AFTER_SECS=60
